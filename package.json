{
  "name": "content-archive",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered personal content archive and intelligent bookmarking system",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run prisma:generate --workspace=apps/web && npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "postinstall": "prisma generate --schema=apps/web/prisma/schema.prisma",
    "prisma:generate": "npm run prisma:generate --workspace=apps/web",
    "prisma:push": "npm run prisma:push --workspace=apps/web",
    "prisma:studio": "npm run prisma:studio --workspace=apps/web",
    "ai:dev": "cd services/ai && uvicorn src.main:app --reload --port 8000",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prisma:seed": "npm run prisma:seed --workspace=apps/web",
    "setup": "npm install && npm run prisma:generate && npm run prisma:push"
  }
}
